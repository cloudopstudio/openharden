{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@openharden/dispatcher",
  "version": "0.0.1",
  "description": "Agente de enrutamiento de openharden. Decide a qué proyecto pertenece cada mensaje del usuario antes de delegar al OpenCode correspondiente.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./prompt": "./src/prompt.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@openharden/shared": "workspace:*",
    "@opencode-ai/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
