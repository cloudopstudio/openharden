{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@openharden/shared",
  "version": "0.0.1",
  "description": "Tipos, schemas zod y catálogo de mensajes (español neutro) compartidos por openharden",
  "type": "module",
  "license": "MIT",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./messages": "./src/messages.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
