{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@openharden/telegram",
  "version": "0.0.1",
  "description": "Adapter de canal Telegram para openharden-gateway. Recibe mensajes y envía respuestas vía Bot API",
  "type": "module",
  "license": "MIT",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@openharden/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
